# Copy to .env for local development:  cp .env.example .env
# In production set these as real environment variables (e.g. Render dashboard).

# REQUIRED — the server's AIsha X-Api-Key. Every video spends this account's
# balance, so keep it secret and consider gating who can use the deployed app.
AISHA_API_KEY=your_x_api_key_here

# Where session folders + the SQLite history DB (aisha.db) live. In Docker this is /app/data.
DATA_DIR=./data

# CORS: comma-separated browser origins allowed to call the API.
# Use your frontend URL(s) in production. "*" allows any (fine for local dev).
AISHA_ALLOWED_ORIGINS=*

# TTS / render defaults (overridable per request within validated limits).
DEFAULT_LANGUAGE=uz
DEFAULT_MOOD=Neutral
DEFAULT_HEIGHT=720
DEFAULT_FPS=24
DEFAULT_DPI=150
# TTS speech rate (uz only). 0 = API default; custom 0.5–2.0.
DEFAULT_SPEED=0.75
TTS_POLL_INTERVAL=3
TTS_POLL_MAX=40

# Audio library (the dashboard browses your Aisha TTS history via GET /api/audios).
AUDIO_PAGE_SIZE=12
# Optional: the exact account-balance endpoint path (relative to https://back.aisha.group),
# e.g. /api/v1/account/. Leave empty to let the server probe a few guesses; the dashboard's
# balance widget is simply hidden if none answer.
AISHA_BALANCE_PATH=
# How long a "build from existing audios" job may wait in AWAITING_PAIRS (slides rendered,
# user still picking audios) before cleanup reaps it.
REUSE_PREPARE_TTL_HOURS=6

# Limits / safety.
MAX_UPLOAD_MB=25
MAX_SLIDES=40
MAX_QUEUE=3

# Session retention (ephemeral-disk hygiene): delete old/excess sessions.
SESSION_MAX_AGE_HOURS=24
SESSION_MAX_COUNT=50

# Logging.
LOG_LEVEL=INFO
